{
	"version": 3,
	"configurePresets": [
		{
			"name": "windows-base",
			"displayName": "Windows x64 Debug",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/out/build/${presetName}",
			"cacheVariables": {
				"CMAKE_C_COMPILER": "cl.exe",
				"CMAKE_CXX_COMPILER": "cl.exe",
				"CMAKE_TOOLCHAIN_FILE": "D:/vcpkg/scripts/buildsystems/vcpkg.cmake",
				"VCPKG_ROOT": "D:/vcpkg",
				"ORT_DIR": "D:/onnxruntime-win-x64-gpu-1.24.1",
				"VCPKG_MANIFEST_MODE": "OFF",
				"VCPKG_TARGET_TRIPLET": "x64-windows",
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "windows-release",
			"inherits": "windows-base",
			"displayName": "Windows x64 Release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		},
		{
			"name": "linux-release",
			"displayName": "Linux x64 Release",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/out/build/${presetName}",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"VCPKG_MANIFEST_MODE": "OFF",
				"VCPKG_TARGET_TRIPLET": "x64-linux",
				"ORT_DIR": "/opt/onnxruntime",
				"PILOT_USE_ORT_CUDA": "ON",
				"PILOT_ENABLE_LOCAL_WINDOW": "OFF"
			}
		}
	],
	"buildPresets": [
		{
			"name": "pilot-debug",
			"displayName": "Build PilotApp Debug",
			"configurePreset": "windows-base",
			"targets": [
				"PilotApp"
			]
		},
		{
			"name": "pilot-release",
			"displayName": "Build PilotApp Release",
			"configurePreset": "windows-release",
			"targets": [
				"PilotApp"
			]
		},
		{
			"name": "all-debug",
			"displayName": "Build All Debug",
			"configurePreset": "windows-base"
		},
		{
			"name": "all-release",
			"displayName": "Build All Release",
			"configurePreset": "windows-release"
		},
		{
			"name": "pilot-linux-release",
			"displayName": "Build PilotApp Linux Release",
			"configurePreset": "linux-release",
			"targets": [
				"PilotApp"
			]
		}
	]
}
